# Copy to deploy.env and edit (deploy.env is gitignored).
#
# Deploy from your Mac:
#   ./scripts/deploy_from_local.sh --sync-portfolio

# --- Connection (pick one) ---

# A) gcloud (recommended if you use Google Cloud SDK)
GCP_PROJECT=your-gcp-project-id
GCP_INSTANCE=dividendscope
GCP_ZONE=us-central1-a

# Linux user on the VM that owns the git clone (if gcloud logs in as someone else)
# GCP_SSH_USER=blidiselalin
# REMOTE_APP_FULL_PATH=/home/blidiselalin/dividend-healthcheck

# B) Plain SSH (set this to skip gcloud)
# SSH_HOST=blidiselalin@34.61.210.2

# Remote app directory on the VM
REMOTE_APP_DIR=dividend-healthcheck

# Portfolio migration (scripts/migrate_portfolio_to_cloud.sh)
# MIGRATE_EMAIL=you@gmail.com

# --- Deploy mode ---
# rsync = copy this repo from your laptop, then rebuild Docker (includes uncommitted changes)
# git   = git pull on the VM only (VM must already have the clone)
DEPLOY_METHOD=rsync

# --- Cloud SQL (optional — single PostgreSQL database for all app data) ---
# On the VM, run Cloud SQL Auth Proxy and set:
# DATABASE_URL=postgresql://app_user:PASSWORD@127.0.0.1:5432/dividendscope
# CLOUD_SQL_INSTANCE=project:region:instance
