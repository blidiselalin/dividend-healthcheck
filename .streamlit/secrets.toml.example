# Copy to `.streamlit/secrets.toml` for local dev, or paste into
# Streamlit Cloud → App settings → Secrets.

# --- Runtime (optional) ---
DIVIDENDSCOPE_CLOUD = "false"
# DIVIDENDSCOPE_DATA_DIR = "/path/to/data"

# --- Google sign-up / sign-in (Streamlit OIDC) ---
# First Google login creates the user automatically (no separate sign-up form).
# 1. Google Cloud Console → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. OAuth consent screen: add test users while in "Testing", or publish for any Google account
# 4. Authorized redirect URIs:
#    - http://localhost:8501/oauth2callback
#    - https://YOUR-APP.streamlit.app/oauth2callback
# 5. Fill values below (generate cookie_secret: openssl rand -hex 32)

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "REPLACE_WITH_RANDOM_HEX"
client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Open sign-up: any Google account can register (default when allowed_emails is unset)
# allow_signup = false

# Invite-only: only these emails may sign up / sign in (comma-separated or TOML list).
# Other Google accounts can request access; admins approve in the sidebar "Access requests" panel.
# allowed_emails = ["you@gmail.com", "partner@gmail.com"]

# Admins see pending access requests and the Users panel in the sidebar
admin_emails = ["you@gmail.com"]

# Local dev without Google (only when client_id is not set)
# dev_email = "you@gmail.com"

# Disable login entirely (single-user local mode, legacy data path)
# disable = true

# Demo account for UI validation (home page + 3 examples, no Google)
test_user_enabled = true
test_user_email = "test@dividendscope.local"
