# Copy to .env on the VM (gitignored). Used by docker compose.
#
# Change POSTGRES_PASSWORD before first production deploy.

POSTGRES_USER=dividendscope
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=dividendscope

# Built automatically by docker-compose from the vars above:
# DATABASE_URL=postgresql://dividendscope:change-me-in-production@postgres:5432/dividendscope

# Optional: SEC EDGAR User-Agent (not an API key; SEC policy requires identification)
# SEC_EDGAR_USER_AGENT=DividendScope/1.0 (you@yourdomain.com)

# Optional: sidebar assistant — FAQ works without keys; HF enables broader chat (server-side only)
# DIVIDENDSCOPE_CHATBOT_ENABLED=1
# HUGGINGFACE_API_KEY=hf_...
# DIVIDENDSCOPE_CHATBOT_MODEL=facebook/blenderbot-400M-distill
